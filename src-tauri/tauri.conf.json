{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jojo-listen",
  "version": "0.1.0",
  "identifier": "com.jojo.listen",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jojo-listen",
        "width": 800,
        "height": 600,
        "decorations": false,
        "alwaysOnTop": true,
        "minWidth": 320,
        "minHeight": 200,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "connect-src http: https:; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$AUDIO/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$HOME/**"],
        "deny": []
      }
    }
  }
}