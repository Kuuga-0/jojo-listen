{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-exists",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "keychain:default",
    "keychain:allow-get",
    "keychain:allow-set",
    "keychain:allow-delete",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "window-state:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}